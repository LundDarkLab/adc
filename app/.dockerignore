# Ignore local archives and large generated files so they are not sent in the build context
archive/
archive/**
archive/*

# Ignore thumbnails, temporary files and model uploads
thumb/
thumb_256/
thumb_512/
models/
archive/tmp/
archive/image/
archive/document/

# Node / PHP deps and VCS
node_modules/
api/vendor/
.git
.gitignore

# DB dumps and env files
db-init/
*.sql
*.sql.gz
.env
.env.local

# macOS
.DS_Store
