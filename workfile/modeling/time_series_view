create or replace view time_series_complete as
select 
  time_series.id as timeline_id,
  time_series.definition as timeline,
  macro_def.id as macro_id,
  macro_def.definition as macro,
  generic.id as generic_id,
  generic.definition as generic,
  `specific`.id as specific_id,
  `specific`.definition as `specific`,
  `specific`.`start`,
  `specific`.`end`
from time_series
inner join time_series_macro macro on macro.serie = time_series.id
left join time_series_macro_definition macro_def on macro.macro = macro_def.id
left join time_series_generic generic on generic.macro = macro.id
left join time_series_specific `specific` on `specific`.generic = generic.id
order by timeline, macro_id, `specific`.`start` asc;